<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="bpmn-generator-skill"
             exporterVersion="1.0">

  <!-- ============================================================ -->
  <!-- SECTION 1: COLLABORATION                                      -->
  <!-- ============================================================ -->
  <collaboration id="collaboration_1">
    <participant id="participant_parent" name="Phụ huynh" processRef="process_parent" />
    <participant id="participant_system" name="Hệ thống" processRef="process_system" />
    <participant id="participant_device" name="Thiết bị con" processRef="process_device" />

    <!-- Message Flows -->
    <messageFlow id="mf_parent_enter_to_system_validate" name="Gửi yêu cầu chặn" sourceRef="task_parent_enter_domain" targetRef="start_system_block" />
    <messageFlow id="mf_system_invalid_to_parent" name="Báo lỗi domain không hợp lệ" sourceRef="task_system_show_invalid" targetRef="task_parent_enter_domain" />
    <messageFlow id="mf_system_duplicate_to_parent" name="Báo trùng lặp" sourceRef="task_system_show_duplicate" targetRef="task_parent_enter_domain" />
    <messageFlow id="mf_system_whitelist_warn_to_parent" name="Cảnh báo xóa khỏi Whitelist" sourceRef="task_system_show_whitelist_warn" targetRef="task_parent_enter_domain" />
    <messageFlow id="mf_system_save_failed_to_parent" name="Báo lưu thất bại" sourceRef="task_system_show_save_failed" targetRef="task_parent_handle_save_failed" />
    <messageFlow id="mf_parent_retry_to_system" name="Yêu cầu thử lại" sourceRef="task_parent_choose_retry" targetRef="task_system_save_db" />
    <messageFlow id="mf_system_to_device_block" name="Lệnh chặn" sourceRef="task_system_push_block_cmd" targetRef="start_device_block" />
    <messageFlow id="mf_parent_unblock_to_system" name="Yêu cầu bỏ chặn" sourceRef="task_parent_click_unblock" targetRef="start_system_unblock" />
    <messageFlow id="mf_system_to_device_unblock" name="Lệnh bỏ chặn" sourceRef="task_system_push_unblock_cmd" targetRef="start_device_unblock" />
  </collaboration>

  <!-- ============================================================ -->
  <!-- SECTION 2: PROCESSES                                          -->
  <!-- ============================================================ -->

  <!-- Process Parent -->
  <process id="process_parent" isExecutable="false">
    <!-- Luồng Chặn Domain -->
    <startEvent id="start_parent_block" name="Yêu cầu chặn domain" />
    <userTask id="task_parent_enter_domain" name="Nhập domain và nhấn Chặn">
      <incoming>sf_parent_start_to_enter</incoming>
    </userTask>
    <userTask id="task_parent_handle_save_failed" name="Chọn Thử lại hoặc Hủy">
      <outgoing>sf_parent_handle_to_gw</outgoing>
    </userTask>
    <exclusiveGateway id="gw_parent_retry_or_cancel" name="Thử lại hay Hủy?">
      <incoming>sf_parent_handle_to_gw</incoming>
      <outgoing>sf_parent_retry</outgoing>
      <outgoing>sf_parent_cancel</outgoing>
    </exclusiveGateway>
    <userTask id="task_parent_choose_retry" name="Nhấn Thử lại">
      <incoming>sf_parent_retry</incoming>
      <outgoing>sf_parent_retry_to_end</outgoing>
    </userTask>
    <endEvent id="end_parent_retry" name="Đã gửi thử lại" />
    <endEvent id="end_parent_block_cancelled" name="Đã hủy chặn" />

    <!-- Luồng Bỏ Chặn Domain -->
    <startEvent id="start_parent_unblock" name="Yêu cầu bỏ chặn domain" />
    <userTask id="task_parent_click_unblock" name="Nhấn Bỏ chặn">
      <incoming>sf_parent_unblock_start_to_click</incoming>
      <outgoing>sf_parent_unblock_click_to_end</outgoing>
    </userTask>
    <endEvent id="end_parent_unblock_sent" name="Đã gửi yêu cầu" />

    <!-- Sequence Flows -->
    <sequenceFlow id="sf_parent_start_to_enter" sourceRef="start_parent_block" targetRef="task_parent_enter_domain" />
    <sequenceFlow id="sf_parent_handle_to_gw" sourceRef="task_parent_handle_save_failed" targetRef="gw_parent_retry_or_cancel" />
    <sequenceFlow id="sf_parent_retry" name="Thử lại" sourceRef="gw_parent_retry_or_cancel" targetRef="task_parent_choose_retry" />
    <sequenceFlow id="sf_parent_cancel" name="Hủy" sourceRef="gw_parent_retry_or_cancel" targetRef="end_parent_block_cancelled" />
    <sequenceFlow id="sf_parent_retry_to_end" sourceRef="task_parent_choose_retry" targetRef="end_parent_retry" />
    <sequenceFlow id="sf_parent_unblock_start_to_click" sourceRef="start_parent_unblock" targetRef="task_parent_click_unblock" />
    <sequenceFlow id="sf_parent_unblock_click_to_end" sourceRef="task_parent_click_unblock" targetRef="end_parent_unblock_sent" />
  </process>

  <!-- Process System -->
  <process id="process_system" isExecutable="false">
    <!-- Luồng Chặn Domain -->
    <startEvent id="start_system_block" name="Nhận yêu cầu chặn" />
    <serviceTask id="task_system_validate" name="Kiểm tra domain hợp lệ">
      <incoming>sf_system_start_to_validate</incoming>
      <outgoing>sf_system_validate_to_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_system_is_valid" name="Hợp lệ?">
      <incoming>sf_system_validate_to_gw</incoming>
      <outgoing>sf_system_valid_yes</outgoing>
      <outgoing>sf_system_valid_no</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_system_show_invalid" name="Hiện lỗi &#39;Domain không hợp lệ&#39;">
      <incoming>sf_system_valid_no</incoming>
      <outgoing>sf_system_invalid_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_invalid" name="Kết thúc (Không hợp lệ)" />

    <serviceTask id="task_system_check_blocked" name="Kiểm tra domain đã bị chặn chưa">
      <incoming>sf_system_valid_yes</incoming>
      <outgoing>sf_system_check_blocked_to_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_system_is_blocked" name="Đã bị chặn?">
      <incoming>sf_system_check_blocked_to_gw</incoming>
      <outgoing>sf_system_blocked_no</outgoing>
      <outgoing>sf_system_blocked_yes</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_system_show_duplicate" name="Hiện báo trùng">
      <incoming>sf_system_blocked_yes</incoming>
      <outgoing>sf_system_duplicate_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_duplicate" name="Kết thúc (Bị trùng)" />

    <serviceTask id="task_system_check_whitelist" name="Kiểm tra xung đột Whitelist">
      <incoming>sf_system_blocked_no</incoming>
      <outgoing>sf_system_check_whitelist_to_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_system_is_whitelist_conflict" name="Xung đột Whitelist?">
      <incoming>sf_system_check_whitelist_to_gw</incoming>
      <outgoing>sf_system_whitelist_no</outgoing>
      <outgoing>sf_system_whitelist_yes</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_system_show_whitelist_warn" name="Hiện cảnh báo xóa khỏi Whitelist">
      <incoming>sf_system_whitelist_yes</incoming>
      <outgoing>sf_system_whitelist_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_whitelist_conflict" name="Kết thúc (Xung đột)" />

    <serviceTask id="task_system_save_db" name="Lưu Database">
      <incoming>sf_system_whitelist_no</incoming>
      <outgoing>sf_system_save_to_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_system_save_db_status" name="Lưu thành công?">
      <incoming>sf_system_save_to_gw</incoming>
      <outgoing>sf_system_save_success</outgoing>
      <outgoing>sf_system_save_failed</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_system_show_save_failed" name="Hiện toast &#39;Lưu thất bại&#39;">
      <incoming>sf_system_save_failed</incoming>
      <outgoing>sf_system_failed_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_save_failed" name="Kết thúc (Lưu lỗi)" />

    <exclusiveGateway id="gw_system_check_device_online" name="Thiết bị con online?">
      <incoming>sf_system_save_success</incoming>
      <outgoing>sf_system_device_online</outgoing>
      <outgoing>sf_system_device_offline</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_system_save_pending" name="Lưu trạng thái &#39;Đang chờ đồng bộ&#39;">
      <incoming>sf_system_device_offline</incoming>
      <outgoing>sf_system_pending_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_block_pending" name="Kết thúc (Chờ đồng bộ)" />

    <serviceTask id="task_system_push_block_cmd" name="Đẩy lệnh chặn xuống thiết bị">
      <incoming>sf_system_device_online</incoming>
      <outgoing>sf_system_push_to_applied</outgoing>
    </serviceTask>
    <serviceTask id="task_system_show_applied" name="Hiện &#39;Đã áp dụng ✓&#39;">
      <incoming>sf_system_push_to_applied</incoming>
      <outgoing>sf_system_applied_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_block_applied" name="Kết thúc (Đã chặn)" />

    <!-- Luồng Bỏ Chặn Domain -->
    <startEvent id="start_system_unblock" name="Nhận yêu cầu bỏ chặn" />
    <serviceTask id="task_system_delete_db" name="Xóa domain khỏi database">
      <incoming>sf_system_unblock_start_to_delete</incoming>
      <outgoing>sf_system_delete_to_push</outgoing>
    </serviceTask>
    <serviceTask id="task_system_push_unblock_cmd" name="Đẩy lệnh cập nhật xuống máy con">
      <incoming>sf_system_delete_to_push</incoming>
      <outgoing>sf_system_unblock_push_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_system_unblock" name="Kết thúc (Đã bỏ chặn)" />

    <!-- Sequence Flows -->
    <sequenceFlow id="sf_system_start_to_validate" sourceRef="start_system_block" targetRef="task_system_validate" />
    <sequenceFlow id="sf_system_validate_to_gw" sourceRef="task_system_validate" targetRef="gw_system_is_valid" />
    <sequenceFlow id="sf_system_valid_yes" name="Có" sourceRef="gw_system_is_valid" targetRef="task_system_check_blocked" />
    <sequenceFlow id="sf_system_valid_no" name="Không" sourceRef="gw_system_is_valid" targetRef="task_system_show_invalid" />
    <sequenceFlow id="sf_system_invalid_to_end" sourceRef="task_system_show_invalid" targetRef="end_system_invalid" />
    <sequenceFlow id="sf_system_check_blocked_to_gw" sourceRef="task_system_check_blocked" targetRef="gw_system_is_blocked" />
    <sequenceFlow id="sf_system_blocked_no" name="Chưa" sourceRef="gw_system_is_blocked" targetRef="task_system_check_whitelist" />
    <sequenceFlow id="sf_system_blocked_yes" name="Có" sourceRef="gw_system_is_blocked" targetRef="task_system_show_duplicate" />
    <sequenceFlow id="sf_system_duplicate_to_end" sourceRef="task_system_show_duplicate" targetRef="end_system_duplicate" />
    <sequenceFlow id="sf_system_check_whitelist_to_gw" sourceRef="task_system_check_whitelist" targetRef="gw_system_is_whitelist_conflict" />
    <sequenceFlow id="sf_system_whitelist_no" name="Không" sourceRef="gw_system_is_whitelist_conflict" targetRef="task_system_save_db" />
    <sequenceFlow id="sf_system_whitelist_yes" name="Có" sourceRef="gw_system_is_whitelist_conflict" targetRef="task_system_show_whitelist_warn" />
    <sequenceFlow id="sf_system_whitelist_to_end" sourceRef="task_system_show_whitelist_warn" targetRef="end_system_whitelist_conflict" />
    <sequenceFlow id="sf_system_save_to_gw" sourceRef="task_system_save_db" targetRef="gw_system_save_db_status" />
    <sequenceFlow id="sf_system_save_success" name="Thành công" sourceRef="gw_system_save_db_status" targetRef="gw_system_check_device_online" />
    <sequenceFlow id="sf_system_save_failed" name="Lỗi mạng" sourceRef="gw_system_save_db_status" targetRef="task_system_show_save_failed" />
    <sequenceFlow id="sf_system_failed_to_end" sourceRef="task_system_show_save_failed" targetRef="end_system_save_failed" />
    <sequenceFlow id="sf_system_device_online" name="Online" sourceRef="gw_system_check_device_online" targetRef="task_system_push_block_cmd" />
    <sequenceFlow id="sf_system_device_offline" name="Offline" sourceRef="gw_system_check_device_online" targetRef="task_system_save_pending" />
    <sequenceFlow id="sf_system_pending_to_end" sourceRef="task_system_save_pending" targetRef="end_system_block_pending" />
    <sequenceFlow id="sf_system_push_to_applied" sourceRef="task_system_push_block_cmd" targetRef="task_system_show_applied" />
    <sequenceFlow id="sf_system_applied_to_end" sourceRef="task_system_show_applied" targetRef="end_system_block_applied" />
    <sequenceFlow id="sf_system_unblock_start_to_delete" sourceRef="start_system_unblock" targetRef="task_system_delete_db" />
    <sequenceFlow id="sf_system_delete_to_push" sourceRef="task_system_delete_db" targetRef="task_system_push_unblock_cmd" />
    <sequenceFlow id="sf_system_unblock_push_to_end" sourceRef="task_system_push_unblock_cmd" targetRef="end_system_unblock" />
  </process>

  <!-- Process Device -->
  <process id="process_device" isExecutable="false">
    <!-- Luồng Chặn Domain -->
    <startEvent id="start_device_block" name="Nhận lệnh chặn" />
    <serviceTask id="task_device_apply_block" name="Chặn domain + subdomain">
      <incoming>sf_device_block_start_to_task</incoming>
      <outgoing>sf_device_block_task_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_device_block" name="Đã áp dụng chặn" />

    <!-- Luồng Bỏ Chặn Domain -->
    <startEvent id="start_device_unblock" name="Nhận lệnh bỏ chặn" />
    <serviceTask id="task_device_apply_unblock" name="Gỡ chặn domain">
      <incoming>sf_device_unblock_start_to_task</incoming>
      <outgoing>sf_device_unblock_task_to_end</outgoing>
    </serviceTask>
    <endEvent id="end_device_unblock" name="Đã gỡ chặn" />

    <!-- Sequence Flows -->
    <sequenceFlow id="sf_device_block_start_to_task" sourceRef="start_device_block" targetRef="task_device_apply_block" />
    <sequenceFlow id="sf_device_block_task_to_end" sourceRef="task_device_apply_block" targetRef="end_device_block" />
    <sequenceFlow id="sf_device_unblock_start_to_task" sourceRef="start_device_unblock" targetRef="task_device_apply_unblock" />
    <sequenceFlow id="sf_device_unblock_task_to_end" sourceRef="task_device_apply_unblock" targetRef="end_device_unblock" />
  </process>

  <!-- ============================================================ -->
  <!-- SECTION 3: DIAGRAM INTERCHANGE (DI)                           -->
  <!-- ============================================================ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="collaboration_1">

      <!-- === POOL SHAPES === -->
      <bpmndi:BPMNShape id="shape_participant_parent" bpmnElement="participant_parent" isHorizontal="true">
        <dc:Bounds x="160" y="160" width="4100" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_participant_system" bpmnElement="participant_system" isHorizontal="true">
        <dc:Bounds x="160" y="400" width="4100" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_participant_device" bpmnElement="participant_device" isHorizontal="true">
        <dc:Bounds x="160" y="640" width="4100" height="200" />
      </bpmndi:BPMNShape>

      <!-- === ELEMENT SHAPES === -->
      <!-- Phụ huynh Pool Elements -->
      <bpmndi:BPMNShape id="shape_start_parent_block" bpmnElement="start_parent_block">
        <dc:Bounds x="250" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_parent_enter_domain" bpmnElement="task_parent_enter_domain">
        <dc:Bounds x="420" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_parent_handle_save_failed" bpmnElement="task_parent_handle_save_failed">
        <dc:Bounds x="1950" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_parent_retry_or_cancel" bpmnElement="gw_parent_retry_or_cancel" isMarkerVisible="true">
        <dc:Bounds x="2120" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_parent_choose_retry" bpmnElement="task_parent_choose_retry">
        <dc:Bounds x="2290" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_parent_retry" bpmnElement="end_parent_retry">
        <dc:Bounds x="2460" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_parent_block_cancelled" bpmnElement="end_parent_block_cancelled">
        <dc:Bounds x="2127" y="312" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_start_parent_unblock" bpmnElement="start_parent_unblock">
        <dc:Bounds x="2970" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_parent_click_unblock" bpmnElement="task_parent_click_unblock">
        <dc:Bounds x="3140" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_parent_unblock_sent" bpmnElement="end_parent_unblock_sent">
        <dc:Bounds x="3310" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Hệ thống Pool Elements -->
      <bpmndi:BPMNShape id="shape_start_system_block" bpmnElement="start_system_block">
        <dc:Bounds x="420" y="482" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_validate" bpmnElement="task_system_validate">
        <dc:Bounds x="590" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_system_is_valid" bpmnElement="gw_system_is_valid" isMarkerVisible="true">
        <dc:Bounds x="760" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_show_invalid" bpmnElement="task_system_show_invalid">
        <dc:Bounds x="930" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_system_invalid" bpmnElement="end_system_invalid">
        <dc:Bounds x="1100" y="602" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_check_blocked" bpmnElement="task_system_check_blocked">
        <dc:Bounds x="930" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_system_is_blocked" bpmnElement="gw_system_is_blocked" isMarkerVisible="true">
        <dc:Bounds x="1100" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_show_duplicate" bpmnElement="task_system_show_duplicate">
        <dc:Bounds x="1270" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_system_duplicate" bpmnElement="end_system_duplicate">
        <dc:Bounds x="1440" y="602" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_check_whitelist" bpmnElement="task_system_check_whitelist">
        <dc:Bounds x="1270" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_system_is_whitelist_conflict" bpmnElement="gw_system_is_whitelist_conflict" isMarkerVisible="true">
        <dc:Bounds x="1440" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_show_whitelist_warn" bpmnElement="task_system_show_whitelist_warn">
        <dc:Bounds x="1610" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_system_whitelist_conflict" bpmnElement="end_system_whitelist_conflict">
        <dc:Bounds x="1780" y="602" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_save_db" bpmnElement="task_system_save_db">
        <dc:Bounds x="1610" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_system_save_db_status" bpmnElement="gw_system_save_db_status" isMarkerVisible="true">
        <dc:Bounds x="1780" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_show_save_failed" bpmnElement="task_system_show_save_failed">
        <dc:Bounds x="1950" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_system_save_failed" bpmnElement="end_system_save_failed">
        <dc:Bounds x="2120" y="602" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_system_check_device_online" bpmnElement="gw_system_check_device_online" isMarkerVisible="true">
        <dc:Bounds x="1950" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_system_save_pending" bpmnElement="task_system_save_pending">
        <dc:Bounds x="2120" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_system_block_pending" bpmnElement="end_system_block_pending">
