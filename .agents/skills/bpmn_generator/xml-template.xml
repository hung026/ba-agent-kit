<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="bpmn-generator-skill"
             exporterVersion="1.0">

  <!-- ============================================================ -->
  <!-- SECTION 1: COLLABORATION                                      -->
  <!-- Contains: participants (pools) + message flows                -->
  <!-- ============================================================ -->
  <collaboration id="collaboration_1">

    <!-- === PARTICIPANTS === -->
    <!-- One <participant> per actor/pool. processRef links to <process> below. -->
    <!--
    <participant id="participant_{actor}" name="{Actor Display Name}" processRef="process_{actor}" />
    -->

    <!-- === MESSAGE FLOWS === -->
    <!-- Cross-pool communication. sourceRef/targetRef are element IDs in DIFFERENT pools. -->
    <!--
    <messageFlow id="mf_{source}_to_{target}" name="{Label}" sourceRef="{source_element_id}" targetRef="{target_element_id}" />
    -->

  </collaboration>

  <!-- ============================================================ -->
  <!-- SECTION 2: PROCESSES                                          -->
  <!-- One <process> block per actor/pool.                           -->
  <!-- Contains: events, tasks, gateways, sequence flows             -->
  <!-- ============================================================ -->

  <!--
  <process id="process_{actor}" isExecutable="false">

    ~~~ EVENTS ~~~
    <startEvent id="start_{actor}" name="Start" />
    <endEvent id="end_{actor}_1" name="End" />

    ~~~ TASKS ~~~
    <userTask id="task_{actor}_{desc}" name="{Task Display Name}">
      <incoming>{incoming_sf_id}</incoming>
      <outgoing>{outgoing_sf_id}</outgoing>
    </userTask>

    <serviceTask id="task_{actor}_{desc}" name="{Task Display Name}">
      <incoming>{incoming_sf_id}</incoming>
      <outgoing>{outgoing_sf_id}</outgoing>
    </serviceTask>

    ~~~ GATEWAYS ~~~
    <exclusiveGateway id="gw_{actor}_{desc}" name="{Condition Question}">
      <incoming>{incoming_sf_id}</incoming>
      <outgoing>{outgoing_sf_yes_id}</outgoing>
      <outgoing>{outgoing_sf_no_id}</outgoing>
    </exclusiveGateway>

    <parallelGateway id="gw_{actor}_{desc}" name="">
      <incoming>{incoming_sf_id}</incoming>
      <outgoing>{outgoing_sf_1_id}</outgoing>
      <outgoing>{outgoing_sf_2_id}</outgoing>
    </parallelGateway>

    ~~~ SEQUENCE FLOWS ~~~
    <sequenceFlow id="sf_{source}_to_{target}" sourceRef="{source_id}" targetRef="{target_id}" />
    <sequenceFlow id="sf_{source}_to_{target}" name="Yes" sourceRef="{gw_id}" targetRef="{yes_target_id}" />
    <sequenceFlow id="sf_{source}_to_{target}" name="No" sourceRef="{gw_id}" targetRef="{no_target_id}" />

  </process>
  -->

  <!-- ============================================================ -->
  <!-- SECTION 3: DIAGRAM INTERCHANGE (DI)                           -->
  <!-- Visual layout — x,y coordinates for every element and flow.   -->
  <!-- See references/layout-algorithm.md for calculation formulas.  -->
  <!-- ============================================================ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="collaboration_1">

      <!-- === POOL SHAPES === -->
      <!--
      <bpmndi:BPMNShape id="shape_participant_{actor}" bpmnElement="participant_{actor}" isHorizontal="true">
        <dc:Bounds x="160" y="{pool_y}" width="{pool_width}" height="200" />
      </bpmndi:BPMNShape>
      -->

      <!-- === ELEMENT SHAPES === -->
      <!-- Start Event (36x36) -->
      <!--
      <bpmndi:BPMNShape id="shape_start_{actor}" bpmnElement="start_{actor}">
        <dc:Bounds x="{x}" y="{y}" width="36" height="36" />
      </bpmndi:BPMNShape>
      -->

      <!-- Task (100x80) -->
      <!--
      <bpmndi:BPMNShape id="shape_task_{actor}_{desc}" bpmnElement="task_{actor}_{desc}">
        <dc:Bounds x="{x}" y="{y}" width="100" height="80" />
      </bpmndi:BPMNShape>
      -->

      <!-- Gateway (50x50) -->
      <!--
      <bpmndi:BPMNShape id="shape_gw_{actor}_{desc}" bpmnElement="gw_{actor}_{desc}" isMarkerVisible="true">
        <dc:Bounds x="{x}" y="{y}" width="50" height="50" />
      </bpmndi:BPMNShape>
      -->

      <!-- End Event (36x36) -->
      <!--
      <bpmndi:BPMNShape id="shape_end_{actor}" bpmnElement="end_{actor}_1">
        <dc:Bounds x="{x}" y="{y}" width="36" height="36" />
      </bpmndi:BPMNShape>
      -->

      <!-- === SEQUENCE FLOW EDGES === -->
      <!-- Horizontal (same lane) — 2 waypoints -->
      <!--
      <bpmndi:BPMNEdge id="edge_sf_{source}_to_{target}" bpmnElement="sf_{source}_to_{target}">
        <di:waypoint x="{source_right_x}" y="{center_y}" />
        <di:waypoint x="{target_left_x}" y="{center_y}" />
      </bpmndi:BPMNEdge>
      -->

      <!-- Gateway "No" branch (goes down then right) — 3 waypoints -->
      <!--
      <bpmndi:BPMNEdge id="edge_sf_gw_to_no" bpmnElement="sf_gw_to_no">
        <di:waypoint x="{gw_center_x}" y="{gw_bottom_y}" />
        <di:waypoint x="{gw_center_x}" y="{no_branch_y}" />
        <di:waypoint x="{target_left_x}" y="{no_branch_y}" />
      </bpmndi:BPMNEdge>
      -->

      <!-- Gateway branch label -->
      <!--
      <bpmndi:BPMNEdge id="edge_sf_gw_to_yes" bpmnElement="sf_gw_to_yes">
        <di:waypoint x="{gw_right_x}" y="{gw_center_y}" />
        <di:waypoint x="{target_left_x}" y="{gw_center_y}" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="{label_x}" y="{label_y}" width="30" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      -->

      <!-- === MESSAGE FLOW EDGES === -->
      <!-- Vertical (cross-pool) — 2 waypoints, same x -->
      <!--
      <bpmndi:BPMNEdge id="edge_mf_{source}_to_{target}" bpmnElement="mf_{source}_to_{target}">
        <di:waypoint x="{element_center_x}" y="{source_pool_bottom_y}" />
        <di:waypoint x="{element_center_x}" y="{target_pool_top_y}" />
      </bpmndi:BPMNEdge>
      -->

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
