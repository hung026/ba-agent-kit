<!--
  PATTERN: p-loop
  Dùng khi: kiểm tra thất bại → QUAY LUI làm lại bước trước (vd nhập sai → nhập lại).
  Mấu chốt: edge loop từ task lỗi quay về task trước (bên trái) — đi ra cạnh TRÁI, vòng lên,
            vào cạnh DƯỚI của task đích → không cắt qua node giữa.

  Layout (1 lane, h=260): y_main=80, y_lower=180 (nhánh lỗi + đường loop)
  Cột 200px: start1 tNhap2 gwCheck3 tXuLy4 end5 ; tBao dưới gwCheck (col3, y_lower)
  → verify.js: SẠCH.
-->
<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram id="p-loop" name="Pattern: Loop quay lui">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="360" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="pool" value="[Tên quy trình]" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=13;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="1010" height="260" as="geometry" />
        </mxCell>
        <mxCell id="lA" value="ACTOR" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=12;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="pool" vertex="1">
          <mxGeometry x="30" y="0" width="980" height="260" as="geometry" />
        </mxCell>

        <mxCell id="start" value="Bắt đầu" style="points=[[0.145,0.145,0],[0.5,0,0],[0.855,0.145,0],[1,0.5,0],[0.855,0.855,0],[0.5,1,0],[0.145,0.855,0],[0,0.5,0]];shape=mxgraph.bpmn.event;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=ellipsePerimeter;outlineConnect=0;aspect=fixed;outline=standard;symbol=general;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="50" y="85" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tNhap" value="Nhập dữ liệu" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="250" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gwCheck" value="Hợp lệ?" style="points=[[0.25,0.25,0],[0.5,0,0],[0.75,0.25,0],[1,0.5,0],[0.75,0.75,0],[0.5,1,0],[0.25,0.75,0],[0,0.5,0]];shape=mxgraph.bpmn.gateway2;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=rhombusPerimeter;outlineConnect=0;outline=none;symbol=none;gwType=exclusive;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="450" y="80" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tXuLy" value="Xử lý dữ liệu" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="650" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="end" value="Kết thúc" style="points=[[0.145,0.145,0],[0.5,0,0],[0.855,0.145,0],[1,0.5,0],[0.855,0.855,0],[0.5,1,0],[0.145,0.855,0],[0,0.5,0]];shape=mxgraph.bpmn.event;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=ellipsePerimeter;outlineConnect=0;aspect=fixed;outline=end;symbol=terminate;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="850" y="85" width="50" height="50" as="geometry" />
        </mxCell>
        <!-- Nhánh lỗi (dưới gwCheck) -->
        <mxCell id="tBao" value="Báo lỗi" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="440" y="180" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="start" target="tNhap" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="tNhap" target="gwCheck" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" value="Hợp lệ" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="gwCheck" target="tXuLy" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="tXuLy" target="end" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Nhánh lỗi xuống dưới -->
        <mxCell id="f5" value="Không hợp lệ" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" parent="1" source="gwCheck" target="tBao" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- LOOP quay lui: ra cạnh trái tBao, vòng lên, vào cạnh dưới tNhap -->
        <mxCell id="f6" value="Nhập lại" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" parent="1" source="tBao" target="tNhap" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
