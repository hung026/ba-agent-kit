<!--
  PATTERN: p-branch-1
  Dùng khi: có 1 exclusive gateway, 2 nhánh rẽ, mỗi nhánh kết thúc riêng.
  Cách dùng: copy cấu trúc, thay label, thêm task vào nhánh nếu cần.

  Layout (lane_B h=240):
    y_main  = 90   → Gateway và task main path
    y_upper = 15   → Nhánh A (lên trên)
    y_lower = 165  → Nhánh B (xuống dưới)

  Cột:  col1=50  col2=250  col3=450  col4=660  col5=860
        start    t1        t2/gw     branch    end
-->
<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram id="p-branch-1" name="Pattern: 1 Gateway 2 Branches">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- POOL -->
        <mxCell id="pool" value="[Tên quy trình]" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=13;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="1050" height="390" as="geometry" />
        </mxCell>

        <!-- Lane A (simple, h=150) -->
        <mxCell id="lA" value="ACTOR_A" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=12;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="pool" vertex="1">
          <mxGeometry x="30" y="0" width="1020" height="150" as="geometry" />
        </mxCell>

        <!-- Lane B (with branches, h=240) -->
        <mxCell id="lB" value="ACTOR_B" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=12;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="pool" vertex="1">
          <mxGeometry x="30" y="150" width="1020" height="240" as="geometry" />
        </mxCell>

        <!-- Lane A nodes -->
        <mxCell id="start" value="Bắt đầu" style="points=[[0.145,0.145,0],[0.5,0,0],[0.855,0.145,0],[1,0.5,0],[0.855,0.855,0],[0.5,1,0],[0.145,0.855,0],[0,0.5,0]];shape=mxgraph.bpmn.event;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=ellipsePerimeter;outlineConnect=0;aspect=fixed;outline=standard;symbol=general;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="50" y="50" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="t1" value="TASK_1" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;container=1;expand=0;collapsible=0;taskMarker=abstract;fontSize=12;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lA" vertex="1">
          <mxGeometry x="150" y="45" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Lane B nodes
             col3 x=450: TASK_2 (pre-gateway)
             col3 x=550: GW_1   (note: task is 140px wide, gw starts after = 450+140+60=650... or reuse col)
             Let's place: TASK_2 at x=350 (y=90), GW_1 at x=550 (y=90), branches at x=660
        -->
        <mxCell id="t2" value="TASK_2" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;container=1;expand=0;collapsible=0;taskMarker=abstract;fontSize=12;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lB" vertex="1">
          <mxGeometry x="350" y="90" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- GW_1: x=550, y=90 (center=120) — main path gateway -->
        <mxCell id="gw1" value="DECISION?" style="points=[[0.25,0.25,0],[0.5,0,0],[0.75,0.25,0],[1,0.5,0],[0.75,0.75,0],[0.5,1,0],[0.25,0.75,0],[0,0.5,0]];shape=mxgraph.bpmn.gateway2;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=rhombusPerimeter;outlineConnect=0;outline=none;symbol=none;gwType=exclusive;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lB" vertex="1">
          <mxGeometry x="550" y="90" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- BRANCH_A: x=660, y=15 (upper) — y_upper=15, bottom=75 → gap to GW top(90)=15px ✓ -->
        <mxCell id="brA" value="BRANCH_A_TASK" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;container=1;expand=0;collapsible=0;taskMarker=abstract;fontSize=12;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lB" vertex="1">
          <mxGeometry x="660" y="15" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- BRANCH_B: x=660, y=165 (lower) — y_lower=165, top=165 → gap to GW bottom(150)=15px ✓ -->
        <mxCell id="brB" value="BRANCH_B_TASK" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;container=1;expand=0;collapsible=0;taskMarker=abstract;fontSize=12;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lB" vertex="1">
          <mxGeometry x="660" y="165" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- END_A: x=850, y=20 (upper) -->
        <mxCell id="endA" value="END_A" style="points=[[0.145,0.145,0],[0.5,0,0],[0.855,0.145,0],[1,0.5,0],[0.855,0.855,0],[0.5,1,0],[0.145,0.855,0],[0,0.5,0]];shape=mxgraph.bpmn.event;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=ellipsePerimeter;outlineConnect=0;aspect=fixed;outline=end;symbol=terminate;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lB" vertex="1">
          <mxGeometry x="850" y="20" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- END_B: x=850, y=170 (lower) -->
        <mxCell id="endB" value="END_B" style="points=[[0.145,0.145,0],[0.5,0,0],[0.855,0.145,0],[1,0.5,0],[0.855,0.855,0],[0.5,1,0],[0.145,0.855,0],[0,0.5,0]];shape=mxgraph.bpmn.event;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=ellipsePerimeter;outlineConnect=0;aspect=fixed;outline=end;symbol=terminate;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lB" vertex="1">
          <mxGeometry x="850" y="170" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;" parent="1" source="start" target="t1" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;" parent="1" source="t1" target="t2" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;" parent="1" source="t2" target="gw1" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f4" value="Nhánh A" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;" parent="1" source="gw1" target="brA" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f5" value="Nhánh B" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;" parent="1" source="gw1" target="brB" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;" parent="1" source="brA" target="endA" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;" parent="1" source="brB" target="endB" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
