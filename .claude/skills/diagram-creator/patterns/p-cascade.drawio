        <mxCell id="ex3" value="EXIT_C" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lC" vertex="1">
          <mxGeometry x="610" y="130" width="140" height="60" as="geometry" />
