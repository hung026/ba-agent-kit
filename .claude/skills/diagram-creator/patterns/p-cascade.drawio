        <mxCell id="f2" value="Tiếp tục" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="gw1" target="gw2" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" value="Tiếp tục" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#000000;fontSize=11;fontColor=#000000;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="gw2" target="gw3" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
