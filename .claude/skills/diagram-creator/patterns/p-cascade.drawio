<!--
  PATTERN: p-cascade  (THAY THẾ cách vẽ cascade cũ bị chồng)
  Dùng khi: ≥2 exclusive gateway nối tiếp, mỗi GW có 1 nhánh thoát riêng.
  Điển hình: chuỗi kiểm tra (check A → check B → check C → else).

  NGUYÊN TẮC: nhánh thoát đi DỌC XUỐNG (không đi ngang) → mỗi GW chỉ tốn 1 cột → KHÔNG chồng.

  Layout (1 lane, h=300):
    Tầng GW   (main): y=30   → GW spans 30–90
    Tầng exit (thoát): y=130 → exit task spans 130–190  (gap 40px)
    Tầng end:          y=230 → end event spans 230–280   (gap 40px)

  Cột (gw_x = 50 + (i−1)×200):  GW1 x=250  GW2 x=450  GW3 x=650
    exit_x = gw_x − 40   |   end_x = gw_x + 5
  → verify.js: SẠCH.
-->
<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram id="p-cascade" name="Pattern: Cascade dọc">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- POOL -->
        <mxCell id="pool" value="[Tên quy trình — chuỗi kiểm tra]" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=13;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="1010" height="300" as="geometry" />
        </mxCell>

        <!-- Lane (h=300) -->
        <mxCell id="lC" value="ACTOR" style="swimlane;html=1;horizontal=0;startSize=30;fontStyle=1;fontSize=12;fillColor=none;strokeColor=#000000;swimlaneFillColor=#ffffff;fontColor=#000000;" parent="pool" vertex="1">
          <mxGeometry x="30" y="0" width="980" height="300" as="geometry" />
        </mxCell>

        <!-- MAIN PATH: col1 task vào, GW1 col2, GW2 col3, GW3 col4, end else col5 -->
        <mxCell id="tIn" value="IN_TASK" style="points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];shape=mxgraph.bpmn.task;whiteSpace=wrap;rectStyle=rounded;size=10;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lC" vertex="1">
          <mxGeometry x="50" y="30" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="gw1" value="CHECK_A?" style="points=[[0.25,0.25,0],[0.5,0,0],[0.75,0.25,0],[1,0.5,0],[0.75,0.75,0],[0.5,1,0],[0.25,0.75,0],[0,0.5,0]];shape=mxgraph.bpmn.gateway2;html=1;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;align=center;perimeter=rhombusPerimeter;outlineConnect=0;outline=none;symbol=none;gwType=exclusive;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;" parent="lC" vertex="1">
          <mxGeometry x="250" y="30" width="60" height="60" as="geometry" />
