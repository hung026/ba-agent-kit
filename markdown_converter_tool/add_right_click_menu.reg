Windows Registry Editor Version 5.00

; --- Thêm cho file PDF ---
[HKEY_CLASSES_ROOT\SystemFileAssociations\.pdf\shell\MarkItDown]
@="Convert to Markdown"
"Icon"="C:\\Users\\PC\\.workspace\\convert_to_markdown\\icon.ico"

[HKEY_CLASSES_ROOT\SystemFileAssociations\.pdf\shell\MarkItDown\command]
@="powershell.exe -NoExit -Command \"C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python312\\python.exe -m markitdown '%1' -o ('%1' -replace '\\.pdf$', '.md')\""


; --- Thêm cho file Word (.docx) ---
[HKEY_CLASSES_ROOT\SystemFileAssociations\.docx\shell\MarkItDown]
@="Convert to Markdown"
"Icon"="C:\\Users\\PC\\.workspace\\convert_to_markdown\\icon.ico"

[HKEY_CLASSES_ROOT\SystemFileAssociations\.docx\shell\MarkItDown\command]
@="powershell.exe -NoExit -Command \"C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python312\\python.exe -m markitdown '%1' -o ('%1' -replace '\\.docx$', '.md')\""